{
  "expo": {
    "name": "Concert Memory Journal",
    "slug": "concert-memory-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.angelicat.concertjournal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.angelicat.concertjournal"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-iap"
    ],
    "scheme": "concert-memory-journal",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "575c7d70-5fab-40be-a03d-40859a6fdb41"
      }
    }
  }
}
